{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["cypress", "node"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "files": ["./support/component.d.ts"],
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.d.ts",
    "../packages/**/src/**/*.cy.ts",
    "../packages/**/src/**/*.cy.tsx",
    "../apps/**/src/**/*.cy.ts",
    "../apps/**/src/**/*.cy.tsx"
  ]
}